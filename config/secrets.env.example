# Discord 通知，可选
DISCORD_BOT_TOKEN=change-me
DISCORD_GUILD_ID=change-me
DISCORD_CHANNEL_ID=
DISCORD_CHANNEL_NAME=quant-highrisk

# OKX / freqtrade 实盘壳子，可选
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSWORD=

# Codex CLI 可选覆盖，通常不需要
CODEX_MODEL=gpt-5.4
CODEX_REASONING_EFFORT=medium
CODEX_SANDBOX=read-only
CODEX_TIMEOUT_SECONDS=600
CODEX_EPHEMERAL=1

# DeepSeek planner-only 实验，可选
# 仅当 MACD_V2_PLANNER_PROVIDER=deepseek 时，planner 改走 DeepSeek；
# reviewer / edit_worker / repair_worker / summary_worker 仍走现有 Codex CLI。
MACD_V2_PLANNER_PROVIDER=codex
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_PLANNER_MODEL=deepseek-v4-pro
DEEPSEEK_PLANNER_THINKING_TYPE=enabled
DEEPSEEK_PLANNER_REASONING_EFFORT=max
DEEPSEEK_PLANNER_TIMEOUT_SECONDS=600
DEEPSEEK_PLANNER_MAX_HISTORY_MESSAGES=80
